# Supabase project credentials
# Get these from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Google Sheets Integration (via Google Apps Script Web App)
# Deploy a Google Apps Script in your spreadsheet as a Web App (see README for script code)
# Deploy settings: Execute as "Me", Who has access "Anyone"
# After deploying, paste the /exec URL here
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/<deployment-id>/exec

# QR Code Values — must match the actual QR code content used at the event
# These are server-side only (no NEXT_PUBLIC_ prefix) — QR content stays out of the client bundle
# The scanned decodedText is sent in the API payload; tipo detection happens server-side
ENTRANCE_QR_VALUE=your_entrance_qr_content_here
EXIT_QR_VALUE=your_exit_qr_content_here
