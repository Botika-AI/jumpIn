# Supabase project credentials
# Get these from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Google Sheets Integration
# Paste the ENTIRE contents of your Google Service Account JSON key file as the value
# (include the outer braces — the full JSON object as a string)
# IMPORTANT: Share the spreadsheet with the service_account client_email as Editor
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"name@project.iam.gserviceaccount.com",...}'
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# QR Code Values — must match the actual QR code content used at the event
# These are server-side only (no NEXT_PUBLIC_ prefix) — QR content stays out of the client bundle
# The scanned decodedText is sent in the API payload; tipo detection happens in the route handler
ENTRANCE_QR_VALUE=your_entrance_qr_content_here
EXIT_QR_VALUE=your_exit_qr_content_here
